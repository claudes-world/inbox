{
  "name": "tryinbox",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @inbox/contracts build",
    "pretest": "pnpm --filter @inbox/contracts build",
    "pretypecheck": "pnpm --filter @inbox/contracts build",
    "dev:bff": "pnpm --filter @inbox/bff dev",
    "dev:ui": "pnpm --filter @inbox/ui dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
