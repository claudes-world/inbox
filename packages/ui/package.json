{
  "name": "@inbox/ui",
  "version": "0.1.0",
  "description": "Inbox dev tooling UI — Operator's Console",
  "type": "module",
  "scripts": {
    "dev": "vite --port 58850",
    "build": "tsc -b && vite build",
