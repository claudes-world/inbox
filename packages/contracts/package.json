{
  "name": "@inbox/contracts",
  "version": "0.2.0",
  "description": "Shared types, Zod schemas, and fixtures for the Inbox messaging system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fixtures": {
      "import": "./dist/fixtures.js",
      "types": "./dist/fixtures.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "zod": "^3.24.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.3.0"
  }
}
