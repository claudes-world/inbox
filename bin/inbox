#!/usr/bin/env bash
set -euo pipefail

# inbox — CLI entrypoint for the Inbox messaging system
# Usage: inbox <command> [options]
# Global flags: --json, --help, --version

_resolve_inbox_script() {
  local real_script="${BASH_SOURCE[0]}"

  if command -v greadlink >/dev/null 2>&1; then
    greadlink -f "$real_script"
  elif command -v readlink >/dev/null 2>&1 && readlink -f /dev/null >/dev/null 2>&1; then
    readlink -f "$real_script"
  else
    while [[ -L "$real_script" ]]; do
      local real_dir link_target
      real_dir="$(cd "$(dirname "$real_script")" && pwd)"
      link_target="$(readlink "$real_script")"
      if [[ "$link_target" == /* ]]; then
        real_script="$link_target"
      else
        real_script="$real_dir/$link_target"
      fi
    done
    printf '%s/%s\n' "$(cd "$(dirname "$real_script")" && pwd)" "$(basename "$real_script")"
  fi
}

REAL_SCRIPT="$(_resolve_inbox_script)"
BIN_DIR="$(dirname "$REAL_SCRIPT")"
PREFIX="$(dirname "$BIN_DIR")"
SCRIPT_DIR="$PREFIX"

_inbox_version() {
  local version_file version
  local candidates=()

  if [[ -n "${INBOX_SHARE_DIR:-}" ]]; then
    candidates+=("$INBOX_SHARE_DIR/../VERSION")
    candidates+=("$INBOX_SHARE_DIR/VERSION")
  else
    candidates+=("$PREFIX/share/inbox/../VERSION")
  fi
  candidates+=("$PREFIX/VERSION")

  for version_file in "${candidates[@]}"; do
    if [[ -f "$version_file" ]]; then
      IFS= read -r version < "$version_file" || true
      if [[ -n "${version:-}" ]]; then
        printf '%s\n' "$version"
        return 0
      fi
    fi
  done

  printf 'unknown\n'
}

# --- Global flag parsing ---
# Extract global flags before subcommand routing. --version must not depend on
# lib discovery so broken installs can still report their installed version.
_ARGS=()
export INBOX_JSON_MODE=0
_SHOW_HELP=0
_SHOW_VERSION=0

for arg in "$@"; do
  case "$arg" in
    --json) INBOX_JSON_MODE=1 ;;
    --help) _SHOW_HELP=1 ;;
    --version|-v) _SHOW_VERSION=1 ;;
    *)      _ARGS+=("$arg") ;;
  esac
done

set -- "${_ARGS[@]+"${_ARGS[@]}"}"

if [[ $_SHOW_VERSION -eq 1 ]]; then
  _inbox_version
  exit 0
fi

INBOX_LIB_DIR="${INBOX_LIB_DIR:-}"

if [[ -z "$INBOX_LIB_DIR" ]]; then
  if [[ -d "$PREFIX/lib/inbox" ]] && compgen -G "$PREFIX/lib/inbox/*.sh" >/dev/null; then
    INBOX_LIB_DIR="$PREFIX/lib/inbox"
  elif [[ -d "$PREFIX/lib" ]] && compgen -G "$PREFIX/lib/*.sh" >/dev/null; then
    INBOX_LIB_DIR="$PREFIX/lib"
  else
    echo "error: cannot locate inbox lib dir (tried $PREFIX/lib/inbox, $PREFIX/lib)" >&2
    exit 1
  fi
fi

INBOX_SHARE_DIR="${INBOX_SHARE_DIR:-$PREFIX/share/inbox}"
export INBOX_SHARE_DIR INBOX_LIB_DIR SCRIPT_DIR

MARKER_COUNT=0
for lib in "$INBOX_LIB_DIR"/*.sh; do
  if head -5 "$lib" 2>/dev/null | grep -q "^# INBOX_LIB_FILE=1$"; then
    MARKER_COUNT=$((MARKER_COUNT + 1))
  fi
done

if [[ $MARKER_COUNT -lt 2 ]]; then
  echo "error: $INBOX_LIB_DIR does not appear to contain inbox lib files (canary marker missing)" >&2
  exit 1
fi

# Source all canary-validated lib modules in deterministic order.
export LC_COLLATE=C
for lib in "$INBOX_LIB_DIR"/*.sh; do
  if head -5 "$lib" 2>/dev/null | grep -q "^# INBOX_LIB_FILE=1$"; then
    source "$lib"
  fi
done

# Initialize experimental mode and telemetry from env
experimental_init
telemetry_init

# --- Help ---
_show_help() {
  cat <<'EOF'
inbox — agent-to-agent messaging CLI

Usage: inbox <command> [options] [--json]

Commands:
  whoami              Show acting identity
  send                Send a new message
  list                List inbox messages
  read <msg_id>       Read a message
  reply <msg_id>      Reply to a message
  ack <msg_id>        Acknowledge a message
  hide <msg_id>       Hide a message
  unhide <msg_id>     Unhide a message
  sent list           List sent messages
  sent read <msg_id>  Read a sent message
  sent hide <msg_id>  Hide a sent message
  sent unhide <msg_id> Unhide a sent message
  thread <cnv_id>     View conversation thread
  directory list      List addresses
  directory show      Show address details
  directory members   List group members
  give-feedback       Submit feature feedback

Global flags:
  --json          Output JSON to stdout (stderr silent)
  --help          Show this help
  --version, -v   Show version

Environment:
  INBOX_ADDRESS   Acting address (required)
  INBOX_DB        SQLite database path (required)
EOF

  # Show experimental surfaces if discovery mode is enabled
  if experimental_is_enabled; then
    echo ""
    experimental_help
  fi
}

if [[ $_SHOW_HELP -eq 1 && $# -eq 0 ]]; then
  _show_help
  exit 0
fi

# --- Environment validation ---
_validate_env() {
  if [[ -z "${INBOX_ADDRESS:-}" ]]; then
    format_error "invalid_argument" "INBOX_ADDRESS environment variable is not set" || exit $?
  fi
  if [[ -z "${INBOX_DB:-}" ]]; then
    format_error "invalid_argument" "INBOX_DB environment variable is not set" || exit $?
  fi
}

# --- DB initialization ---
_ensure_db() {
  if ! db_init 2>/dev/null; then
    format_error "internal_error" "failed to initialize database" || exit $?
  fi
}

# --- Subcommand routing ---
_subcommand="${1:-}"

if [[ -z "$_subcommand" ]]; then
  if [[ "$INBOX_JSON_MODE" == "1" ]]; then
    error_json "invalid_argument" "no command specified"
    exit "$EXIT_INVALID_ARGUMENT"
  else
    _show_help
    exit "$EXIT_INVALID_ARGUMENT"
  fi
fi

shift

# Start telemetry timing
_telem_start=$(telemetry_start_command)
_telem_argv="$_subcommand $*"
_cmd_exit=0

_run_command() {
  case "$_subcommand" in
    whoami)
      _validate_env
      _ensure_db
      cmd_whoami "$@"
      ;;
    send)
      _validate_env
      _ensure_db
      cmd_send "$@"
      ;;
    list)
      _validate_env
      _ensure_db
      cmd_list "$@"
      ;;
    read)
      _validate_env
      _ensure_db
      cmd_read "$@"
      ;;
    reply)
      _validate_env
      _ensure_db
      cmd_reply "$@"
      ;;
    ack)
      _validate_env
      _ensure_db
      cmd_ack "$@"
      ;;
    hide)
      _validate_env
      _ensure_db
      cmd_hide "$@"
      ;;
    unhide)
      _validate_env
      _ensure_db
      cmd_unhide "$@"
      ;;
    sent)
      _validate_env
      _ensure_db
      _sent_sub="${1:-}"
      if [[ -z "$_sent_sub" ]]; then
        format_error "invalid_argument" "sent requires a subcommand: list, read, hide, unhide" || return $?
      fi
      shift
      case "$_sent_sub" in
        list)   cmd_sent_list "$@" ;;
        read)   cmd_sent_read "$@" ;;
        hide)   cmd_sent_hide "$@" ;;
        unhide) cmd_sent_unhide "$@" ;;
        *)
          format_error "invalid_argument" "unknown sent subcommand: $_sent_sub" || return $?
          ;;
      esac
      ;;
    thread)
      _validate_env
      _ensure_db
      cmd_thread "$@"
      ;;
    directory)
      _validate_env
      _ensure_db
      _dir_sub="${1:-}"
      if [[ -z "$_dir_sub" ]]; then
        format_error "invalid_argument" "directory requires a subcommand: list, show, members" || return $?
      fi
      shift
      case "$_dir_sub" in
        list)    cmd_directory_list "$@" ;;
        show)    cmd_directory_show "$@" ;;
        members) cmd_directory_members "$@" ;;
        *)
          format_error "invalid_argument" "unknown directory subcommand: $_dir_sub" || return $?
          ;;
      esac
      ;;
    give-feedback)
      _validate_env
      _ensure_db
      cmd_give_feedback "$@"
      ;;
    help)
      _show_help
      return 0
      ;;
    *)
      # Check if this is an experimental surface before reporting unknown command
      if experimental_check "$_subcommand"; then
        experimental_probe "$_subcommand" "verb" || return $?
      else
        format_error "invalid_argument" "unknown command: $_subcommand" || return $?
      fi
      ;;
  esac
}

_run_command "$@" || _cmd_exit=$?

# Finish telemetry timing
telemetry_finish_command "$_telem_start" "$_subcommand" "$_cmd_exit" "$_telem_argv"

exit "$_cmd_exit"
