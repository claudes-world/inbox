# Inbox environment variables
# Copy to .env and fill in values.

# Path to the SQLite database file
INBOX_DB=./inbox.db

# Acting address for this agent (e.g. pm-alpha@vps-1)
INBOX_ADDRESS=

# Experimental profile: "core" (default) or "frontier"
INBOX_PROFILE=core

# Telemetry output file (NDJSON). Leave empty to disable.
INBOX_TELEMETRY_FILE=

# Telemetry capture mode: "safe" (default) or "dangerous-full-context"
INBOX_TELEMETRY_MODE=safe
